# Discord Developer Portalで発行したBotトークン
DISCORD_TOKEN=replace_me

# サーバーIDを入れるとスラッシュコマンド反映が速くなります
# 複数サーバーに入れる場合はカンマ区切り: 123,456
SYNC_GUILD_ID=

# サーバー管理権限がなくても管理コマンドを使えるDiscordユーザーID
# 複数ある場合はカンマ区切り: 123,456
OWNER_IDS=

# ログDBの保存先
DATABASE_PATH=data/bot.sqlite3

# ログ保存日数。0にすると自動削除しません
RETENTION_DAYS=180

# Cacheのテキストコマンドprefix
COMMAND_PREFIX=-

# Discordへチャット形式で残すログチャンネル名
SERVER_LOG_CHANNEL_NAME=server-log

# 参加済み/新規参加サーバーへスラッシュコマンドを自動反映する
AUTO_SYNC_ALL_GUILDS=1
